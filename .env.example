DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,web,testserver
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local (no Docker): SQLite. Docker Compose overrides with Postgres.
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# Without Redis worker use 1. Docker Compose sets 0 for web/worker.
CELERY_TASK_ALWAYS_EAGER=1

# Bitrix24 local app credentials
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
BITRIX_APPLICATION_TOKEN=

# «Оплачено» не трогаем; «Остаток» уменьшаем при каждой зафиксированной сессии таймера.
BITRIX_DEAL_PAID_HOURS_FIELD=
BITRIX_DEAL_REMAINING_HOURS_FIELD=
# Поле сделки «Ссылка на портал Битрикс24» — по нему ищем сделку клиента
BITRIX_DEAL_PORTAL_LINK_FIELD=UF_CRM_1784732110930
# Поле компании «ID проекта» (Bitrix workgroup / GROUP_ID)
BITRIX_COMPANY_PROJECT_ID_FIELD=UF_CRM_1784732577491
# ID воронки «Сопровождение» (CATEGORY_ID)
BITRIX_ACCOMPANIMENT_CATEGORY_ID=

# Public URL of this backend (must be HTTPS for Bitrix cloud install)
PUBLIC_APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Dev bypass: set to 1 to allow JWT login without Bitrix
DEV_AUTH_BYPASS=1

# Agency portal (comma-separated). All other portals = client.
AGENCY_MEMBER_IDS=
AGENCY_DOMAINS=
