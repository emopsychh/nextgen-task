# Copy to .env.production and fill in before:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=tasks.example.com
# Same origin for SPA + API (nginx proxies /api)
CORS_ALLOWED_ORIGINS=https://tasks.example.com
CSRF_TRUSTED_ORIGINS=https://tasks.example.com

POSTGRES_DB=nextgen_task
POSTGRES_USER=nextgen
POSTGRES_PASSWORD=change-me-strong-db-password

# Compose injects DATABASE_URL / Redis; these are fallbacks
DATABASE_URL=postgres://nextgen:change-me-strong-db-password@postgres:5432/nextgen_task
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Public HTTPS URLs (Bitrix handlers + SPA)
PUBLIC_APP_URL=https://tasks.example.com
FRONTEND_URL=https://tasks.example.com

# Host port mapped to frontend nginx
HTTP_PORT=80

# Bitrix local app (agency) — fill after creating the app
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
# application_token is NOT shown in the Bitrix app UI — it is generated by Bitrix
# and delivered inside ONAPPINSTALL / event payloads. The app captures it
# automatically on the first *verified* event, so you can leave this EMPTY.
# Optionally pin it here (copy from server logs / event payload) to require an
# exact match for every event.
BITRIX_APPLICATION_TOKEN=

# Uploaded files are served only via the authenticated download endpoint.
# Signed link lifetime in seconds (default 12h). nginx serves bytes via
# X-Accel-Redirect (MEDIA_USE_X_ACCEL is set to 1 in docker-compose.prod.yml).
ATTACHMENT_URL_TTL=43200

# JWT lifetimes. Access is short-lived (auto-refreshed by the SPA); a leaked /
# logged access token is useless after this many minutes. Refresh tokens rotate
# and old ones are blacklisted on every refresh.
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# Deal hour UF fields + portal link + company project id + accompaniment funnel
BITRIX_DEAL_PAID_HOURS_FIELD=
BITRIX_DEAL_REMAINING_HOURS_FIELD=
BITRIX_DEAL_PORTAL_LINK_FIELD=UF_CRM_1784732110930
BITRIX_COMPANY_PROJECT_ID_FIELD=UF_CRM_1784732577491
BITRIX_ACCOMPANIMENT_CATEGORY_ID=

# Must be 0 in production
DEV_AUTH_BYPASS=0

# Agency portal identity (comma-separated). Everyone else = client.
# Use Bitrix member_id and/or domain, e.g. nextgen.bitrix24.ru
AGENCY_MEMBER_IDS=
AGENCY_DOMAINS=
